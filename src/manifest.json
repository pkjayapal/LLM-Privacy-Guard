{
  "manifest_version": 3,
  "name": "LLM Privacy Guard (MVP)",
  "version": "0.1.0",
  "description": "Warns before sending sensitive data to LLMs. Local-only, lightweight.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LLM Privacy Guard"
  }
}